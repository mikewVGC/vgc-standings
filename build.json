{
    "builder": {
        "steps": [
            "home",
            "season",
            "tournament"
        ],
        "refs": {
            "tpl": "site/templates",
            "js": "site/js",
            "css": "site/css"
        },
        "home": {
            "type": "html",
            "base-ref": "home",
            "out": "public/static/index.html",
            "tokens": [
                {
                    "token": "__TEMPLATE_HEADER__",
                    "type": "tpl",
                    "ref": "header"
                },
                {
                    "token": "__TEMPLATE_HEAD__",
                    "type": "tpl",
                    "ref": "head"
                },
                {
                    "token": "__TEMPLATE_FOOTER__",
                    "type": "tpl",
                    "ref": "footer"
                },
                {
                    "token": "__GOOGLE_ANALYTICS__",
                    "type": "tpl",
                    "ref": "analytics"
                },
                {
                    "token": "__GOOGLE_TAG__",
                    "type": "value",
                    "location": "config",
                    "key": "googleTag"
                },
                {
                    "token": "__BOOTSTRAP_DATA__",
                    "type": "value",
                    "location": "function",
                    "name": "ops.home_bootstrap.get_home_bootstrap_data"
                },
                {
                    "token": "__VUE__",
                    "type": "flag",
                    "name": "prod",
                    "values": [
                        { "value": true, "type": "tpl", "ref": "vue-prod" },
                        { "value": false, "type": "tpl", "ref": "vue" }
                    ]
                },
                {
                    "token": "__SCRIPT_FILE__",
                    "type": "flag",
                    "name": "prod",
                    "values": [
                        { "value": true, "type": "file", "ref": "home-js-min", "ts": true },
                        { "value": false, "type": "file", "ref": "home-js-", "ts": true }
                    ]
                },
                {
                    "token": "__STYLESHEET_FILE__",
                    "type": "flag",
                    "name": "prod",
                    "values": [
                        { "value": true, "type": "file", "ref": "main-css-min", "ts": true },
                        { "value": false, "type": "file", "ref": "main-css", "ts": true }
                    ]
                }
            ]
        },
        "season": {
            "skip": true
        },
        "tournament": {
            "skip": true
        }
    },
    "packer": {
        "tpl_dir": "site",
        "out_dir": "public/static",
        "css": {
            "css/style.css": "main.min.css"
        },
        "js": {
            "js/home.js": "home.min.js",
            "js/season.js": "season.min.js",
            "js/tournament.js": "tournament.min.js"
        }
    }
}
